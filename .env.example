# ── ADU Client Selections checklist (/projects/adu-collaborator) ──
# Shared edit password. Viewing the checklist is open to anyone with the link,
# but SAVING changes requires this password. Set it locally in .env.local and
# in Netlify under Site settings → Environment variables.
ADU_EDIT_PASSWORD=

# Optional: only needed if Netlify Blobs cannot auto-resolve its runtime context
# (it works automatically on Netlify; these are an escape hatch for other hosts).
# NETLIFY_SITE_ID=
# NETLIFY_BLOBS_TOKEN=
